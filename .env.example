# ===== TELEGRAM BOT CONFIGURATION (REQUIRED) =====
# Get your bot token from @BotFather on Telegram
# Create bot: https://t.me/botfather
# Command: /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram numeric user ID for receiving notifications
# Get it from @userinfobot: https://t.me/userinfobot
# Or use: https://t.me/username_to_id_bot
TELEGRAM_CHAT_ID=your_chat_id_here

# Telegram Admin IDs (comma-separated for multiple admins)
# These users can approve/decline verification codes via Telegram buttons
# Example: 123456789,987654321
TELEGRAM_ADMIN_IDS=your_admin_id_here

# ===== SITE CONFIGURATION =====
# Site name shown in Telegram messages
SITE_NAME=Your Flex Benefit
NEXT_PUBLIC_SITE_NAME=Your Flex Benefit

# ===== VERCEL KV CONFIGURATION (REQUIRED FOR PRODUCTION) =====
# Vercel KV stores verification codes with persistent state
# Create database: Vercel Dashboard → Storage → Create Database → KV
# Copy credentials from KV database details page

# Redis connection URL
KV_URL=

# REST API endpoint
KV_REST_API_URL=

# REST API authentication token
KV_REST_API_TOKEN=

# Read-only token (optional for advanced use)
KV_REST_API_READ_ONLY_TOKEN=

