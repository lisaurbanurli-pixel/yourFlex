# Telegram Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID(s) for admin notifications
# Multiple chat IDs can be separated by commas
TELEGRAM_CHAT_ID=your_chat_id_here

# Site name for Telegram messages
SITE_NAME=Your Flex Benefit
NEXT_PUBLIC_SITE_NAME=Your Flex Benefit

# Telegram Admin IDs (comma-separated)
# These users can approve/decline verification codes
TELEGRAM_ADMIN_IDS=your_admin_id_here

# Vercel KV Configuration (if using Vercel KV)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
